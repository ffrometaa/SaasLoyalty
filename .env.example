# ============================================
# LOYALTYOS - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local for each app
# and fill in your values

# ============================================
# SUPABASE (All Apps)
# ============================================
# Found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (dashboard, supabase/functions)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-database-password

# ============================================
# STRIPE (Web + Supabase Functions)
# ============================================
# Found in: Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Found in: Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Found in: Stripe Dashboard > Products
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_SCALE_PRICE_ID=price_xxx

# Coupon for launch discount
STRIPE_LAUNCH_COUPON_ID=xxx

# ============================================
# RESEND (Email - All Apps)
# ============================================
# Found in: Resend Dashboard > API Keys
RESEND_API_KEY=re_xxx

# ============================================
# PUSH NOTIFICATIONS (Future - Phase 2)
# ============================================
# ONE SIGNAL
# ONESIGNAL_APP_ID=xxx
# ONESIGNAL_API_KEY=xxx

# ============================================
# APP URLS
# ============================================
# Used for redirects, OAuth callbacks, emails

# Local Development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001
NEXT_PUBLIC_MEMBER_URL=http://localhost:3002

# Production
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.yourdomain.com
# NEXT_PUBLIC_MEMBER_URL=https://rewards.yourdomain.com

# ============================================
# DOMAIN CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_DOMAIN=localhost
# For production: yourdomain.com

# ============================================
# CUSTOMERSUITE (Optional - Phase 2)
# ============================================
# CUSTOMERSUITE_API_KEY=xxx
# CUSTOMERSUITE_WEBHOOK_SECRET=xxx

# ============================================
# DEVELOPMENT
# ============================================
# Set to 'development' for local dev, 'production' for live
NODE_ENV=development

# Skip Stripe webhook signature verification (dev only!)
STRIPE_SKIP_WEBHOOK_VERIFICATION=false
