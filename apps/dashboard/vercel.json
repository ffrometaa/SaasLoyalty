{
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@loyalty-os/dashboard",
  "devCommand": "npm run dev",
  "installCommand": "cd ../.. && pnpm install",
  "regions": ["iad1"],
  "github": {
    "silent": true
  },
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
